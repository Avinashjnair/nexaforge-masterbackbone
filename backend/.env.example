# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexaforge
DB_USER=nexaforge_api
DB_PASSWORD=change_me_in_production
DB_SSL=false

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── File Storage (MinIO / S3) ──────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nexaforge-docs
MINIO_USE_SSL=false

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5500

# ─── Monitoring (Sentry) ────────────────────────────────────────
# Leave blank to disable Sentry (safe for local dev)
SENTRY_DSN=

# ─── Web Push (VAPID) ───────────────────────────────────────────
# Generate: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@nexaforge.com

# ─── MQTT ───────────────────────────────────────────────────────
# Dev (plaintext):
MQTT_URL=mqtt://localhost:1883
# Production (TLS — generate certs with: bash scripts/gen-mqtt-certs.sh):
# MQTT_URL=mqtts://mosquitto:8883
# MQTT_TLS=true
# MQTT_CA_CERT=/app/mosquitto/certs/ca.crt
# MQTT_REJECT_UNAUTHORIZED=true
# MQTT_USERNAME=nexaforge
# MQTT_PASSWORD=change_me_in_production
